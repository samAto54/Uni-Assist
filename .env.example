# Example environment variables for Uni-Assist
# Copy this to `.env` and fill in real secret values for local development.

# Supabase (public keys for client apps)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Geoapify (public)
EXPO_PUBLIC_GEOAPIFY_API_KEY=

# GROK (server-side) - set only on the server / in CI secrets
# GROK_API_KEY should be kept secret and NOT exposed to client bundles
GROK_API_KEY=
# Optional: custom Grok API endpoint (defaults to https://api.grok.ai/v1/chat/completions)
GROK_API_URL=
# Optional: Grok model name to request (defaults to grok-1)
GROK_MODEL=

# OpenAI (server-side)
OPENAI_API_KEY=

# DeepSeek (server-side)
DEEPSEEK_API_KEY=

# Google Gemini (server-side)
GEMINI_API_KEY=

# Chat server URL used by the client when running against a remote dev server
EXPO_PUBLIC_CHAT_API_URL=http://localhost:4000

# Development flags
# Enable extra server-side provider debug logs: true/false
AI_DEBUG=false

# DO NOT commit real secrets to version control. Use CI/secret manager for production.
